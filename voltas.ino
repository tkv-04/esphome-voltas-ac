/*
 * ============================================================
 *  Voltas AC IR Remote Controller
 *  Remote Model: RG52E1/BGEF
 * ============================================================
 *  Hardware: Arduino Uno + IR LED on pin 4
 *  Protocol: Raw IR timing data captured from original remote
 *  
 *  Serial Commands (115200 baud):
 *    POWER_ON        - Turn AC on (Cool 24°C, Fan Auto)
 *    POWER_OFF       - Turn AC off
 *    TEMP <16-30>    - Set temperature (e.g. TEMP 26)
 *    TEMP_UP         - Increase temp by 1
 *    TEMP_DOWN       - Decrease temp by 1
 *    MODE <mode>     - Set mode: COOL, DRY, HEAT, FAN, AUTO
 *    FAN <speed>     - Set fan: AUTO, LOW, MED, HIGH
 *    SWING_ON        - Enable swing
 *    SWING_OFF       - Disable swing
 *    STATUS          - Print current AC state
 *    HELP            - Show command list
 * ============================================================
 */

#include <IRremote.h>

#define IR_SEND_PIN 4

// ===================== AC STATE TRACKING =====================

struct ACState {
  bool     power;
  int      temp;       // 17–30
  uint8_t  mode;       // 0=COOL, 1=DRY, 2=HEAT, 3=FAN, 4=AUTO
  uint8_t  fan;        // 0=AUTO, 1=LOW, 2=MED, 3=HIGH
  bool     swing;
  bool     led;        // display on/off
};

ACState ac = { false, 24, 0, 0, false, true };

