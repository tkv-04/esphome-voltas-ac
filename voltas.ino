  Serial.println(F("  HELP             Show this menu"));
  Serial.println(F("============================================="));
  Serial.println(F(""));
}

// =================== SERIAL COMMAND PARSER ===================

String inputBuffer = "";

void processCommand(String cmd) {
  cmd.trim();
  cmd.toUpperCase();
  
  if (cmd.length() == 0) return;
  
  Serial.print(F("[CMD] "));
  Serial.println(cmd);
  
  // ---------- POWER ----------
  if (cmd == "POWER_ON") {
    sendPowerOn();
  }
  else if (cmd == "POWER_OFF") {
    sendPowerOff();
  }
  // ---------- TEMPERATURE ----------
  else if (cmd.startsWith("TEMP ")) {
    int t = cmd.substring(5).toInt();
    sendTemp(t);
  }
  else if (cmd == "TEMP_UP") {
    if (ac.temp < 30) {
      sendTemp(ac.temp + 1);
    } else {
      Serial.println(F("Already at max temp (30)"));
    }
  }
  else if (cmd == "TEMP_DOWN") {
    if (ac.temp > 17) {
      sendTemp(ac.temp - 1);
    } else {
      Serial.println(F("Already at min temp (17)"));
    }
  }
  // ---------- MODE ----------
  else if (cmd.startsWith("MODE ")) {
    String m = cmd.substring(5);
    m.trim();
    if      (m == "COOL") sendMode(0);
    else if (m == "DRY")  sendMode(1);
    else if (m == "HEAT") sendMode(2);
    else if (m == "FAN")  sendMode(3);
    else if (m == "AUTO") sendMode(4);
    else Serial.println(F("ERROR: Mode must be COOL|DRY|HEAT|FAN|AUTO"));
  }
  // ---------- FAN ----------
  else if (cmd.startsWith("FAN ")) {
    String f = cmd.substring(4);
    f.trim();
    if      (f == "AUTO") sendFan(0);
    else if (f == "LOW")  sendFan(1);
    else if (f == "MED")  sendFan(2);
    else if (f == "HIGH") sendFan(3);
    else Serial.println(F("ERROR: Fan must be AUTO|LOW|MED|HIGH"));
  }
  // ---------- SWING ----------
  else if (cmd == "SWING_ON") {
    sendSwing(true);
  }
  else if (cmd == "SWING_OFF") {
    sendSwing(false);
  }
  // ---------- LED ----------
  else if (cmd == "LED_ON") {
    sendLed(true);
  }
  else if (cmd == "LED_OFF") {
    sendLed(false);
  }
  // ---------- STATUS / HELP ----------
  else if (cmd == "STATUS") {
    printStatus();
  }
  else if (cmd == "HELP") {
    printHelp();
  }
  else {
    Serial.print(F("Unknown command: "));
    Serial.println(cmd);
    Serial.println(F("Type HELP for available commands"));
  }
  
  Serial.println(F("OK"));
}

// =================== SETUP & LOOP ===================

void setup() {
  Serial.begin(115200);
  while (!Serial) { ; }  // Wait for serial on Uno
  
  IrSender.begin(IR_SEND_PIN);
  
  Serial.println(F(""));
  Serial.println(F("============================================"));
  Serial.println(F("  Voltas AC IR Controller v2.0"));
  Serial.println(F("  Remote: RG52E1/BGEF"));
  Serial.println(F("  IR LED: Pin 4 | Carrier: 38kHz"));
  Serial.println(F("============================================"));
  Serial.println(F("  Type HELP for commands"));
  Serial.println(F("============================================"));
  Serial.println(F(""));
}

void loop() {
  // Read serial commands character by character
  while (Serial.available()) {
    char c = Serial.read();
    
    if (c == '\n' || c == '\r') {
      if (inputBuffer.length() > 0) {
        processCommand(inputBuffer);
        inputBuffer = "";
      }
    } else {
      inputBuffer += c;
    }
  }
}