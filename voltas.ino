// =================== HELPER: SEND RAW FROM PROGMEM ===================
// Arduino Uno has limited SRAM (~2KB), so we read from PROGMEM in chunks

void sendRawFromProgmem(const uint16_t* data, uint16_t len) {
  // IRremote's sendRaw needs the data in RAM.
  // We copy small chunks at a time to avoid blowing SRAM.
  // But for reliability, we allocate a temporary buffer.
  // On Uno, max signal is ~200 entries = 400 bytes — fits.
  
  uint16_t* buf = (uint16_t*)malloc(len * sizeof(uint16_t));
  if (!buf) {
    Serial.println(F("ERROR: Out of memory!"));
    return;
  }
  
  for (uint16_t i = 0; i < len; i++) {
    buf[i] = pgm_read_word(&data[i]);
  }
  
  IrSender.sendRaw(buf, len, 38);
  free(buf);
}

// =================== COMMAND HANDLERS ===================

void sendPowerOn() {
  Serial.println(F(">> POWER ON (Cool 24°C Fan Auto)"));
  sendRawFromProgmem(powerOn, powerOnLen);
  ac.power = true;
  ac.temp  = 24;
  ac.mode  = 0;  // COOL
  ac.fan   = 0;  // AUTO
  ac.swing = false;
}

void sendPowerOff() {
  Serial.println(F(">> POWER OFF"));
  sendRawFromProgmem(powerOff, powerOffLen);
  ac.power = false;
}

void sendTemp(int t) {
  if (t < 17 || t > 30) {
    Serial.println(F("ERROR: Temp must be 17-30"));
    return;
  }
  
  Serial.print(F(">> SET TEMP: "));
  Serial.print(t);
  Serial.println(F("°C"));
  
  switch (t) {
    case 17: sendRawFromProgmem(temp17, temp17Len); break;
    case 18: sendRawFromProgmem(temp18, temp18Len); break;
    case 19: sendRawFromProgmem(temp19, temp19Len); break;
    case 20: sendRawFromProgmem(temp20, temp20Len); break;
    case 21: sendRawFromProgmem(temp21, temp21Len); break;
    case 22: sendRawFromProgmem(temp22, temp22Len); break;
    case 23: sendRawFromProgmem(temp23, temp23Len); break;
    case 24: sendRawFromProgmem(temp24, temp24Len); break;
    case 25: sendRawFromProgmem(temp25, temp25Len); break;
    case 26: sendRawFromProgmem(temp26, temp26Len); break;
    case 27: sendRawFromProgmem(temp27, temp27Len); break;
    case 28: sendRawFromProgmem(temp28, temp28Len); break;
    case 29: sendRawFromProgmem(temp29, temp29Len); break;
    case 30: sendRawFromProgmem(temp30, temp30Len); break;
  }
  ac.temp = t;
}

void sendMode(uint8_t m) {
  Serial.print(F(">> SET MODE: "));
  Serial.println(modeNames[m]);
  
  switch (m) {
    case 0: sendRawFromProgmem(modeCool, modeCoolLen); break;
    case 1: sendRawFromProgmem(modeDry,  modeDryLen);  break;
    case 2: sendRawFromProgmem(modeHeat, modeHeatLen); break;
    case 3: sendRawFromProgmem(modeFan,  modeFanLen);  break;
    case 4: sendRawFromProgmem(modeAuto, modeAutoLen); break;
  }
  ac.mode = m;
}

void sendFan(uint8_t f) {
  Serial.print(F(">> SET FAN: "));
  Serial.println(fanNames[f]);
  
  switch (f) {
    case 0: sendRawFromProgmem(fanAuto, fanAutoLen); break;
    case 1: sendRawFromProgmem(fanLow,  fanLowLen);  break;
    case 2: sendRawFromProgmem(fanMed,  fanMedLen);  break;
    case 3: sendRawFromProgmem(fanHigh, fanHighLen); break;
  }
  ac.fan = f;
}

void sendSwing(bool on) {
  Serial.print(F(">> SWING: "));
  Serial.println(on ? F("ON") : F("OFF"));
  
  if (on) {
    sendRawFromProgmem(swingOn, swingOnLen);
  } else {
    sendRawFromProgmem(swingOff, swingOffLen);
  }
  ac.swing = on;
}

void sendLed(bool on) {
  Serial.print(F(">> LED DISPLAY: "));
  Serial.println(on ? F("ON") : F("OFF"));
  
  if (on) {
    sendRawFromProgmem(ledOn, ledOnLen);
  } else {
    sendRawFromProgmem(ledOff, ledOffLen);
  }
  ac.led = on;
}

void printStatus() {
  Serial.println(F(""));
  Serial.println(F("===== AC STATUS ====="));
  Serial.print(F("  Power : ")); Serial.println(ac.power ? F("ON") : F("OFF"));
  Serial.print(F("  Temp  : ")); Serial.print(ac.temp); Serial.println(F("°C"));
  Serial.print(F("  Mode  : ")); Serial.println(modeNames[ac.mode]);
  Serial.print(F("  Fan   : ")); Serial.println(fanNames[ac.fan]);
  Serial.print(F("  Swing : ")); Serial.println(ac.swing ? F("ON") : F("OFF"));
  Serial.print(F("  LED   : ")); Serial.println(ac.led ? F("ON") : F("OFF"));
  Serial.println(F("====================="));
  Serial.println(F(""));
}

